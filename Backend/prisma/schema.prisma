// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User model
model User {
  id          Int      @id @default(autoincrement())
  firebaseUid String?  @unique
  email       String   @unique
  password    String?
  name        String?
  onboardingDone Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expense     UserExpense?
  asset       UserAsset?
  retirement  UserRetirement?

  portfolios  Portfolio[]
  savedPortfolios SavedPortfolio[]
}

// ─── Normalized Finance Data Models ──────────────────────────────────────

model UserExpense {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  food        Float    @default(0)
  rent        Float    @default(0)
  transport   Float    @default(0)
  necessities Float    @default(0)
  other       Float    @default(0)
  debt        Float    @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserAsset {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  currentCapital Float    @default(0)
  emergencyFund  Float    @default(0)
  monthlySavings Float    @default(0)
  retirementGoal Float    @default(0)
  monthlyIncome  Float?   @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model UserRetirement {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  currentAge     Int      @default(25)
  retirementAge  Int      @default(60)
  initialCapital Float    @default(0)
  monthlySavings Float    @default(0)
  dividendGoal   Float    @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Asset model for financial instruments
model Asset {
  id          Int     @id @default(autoincrement())
  symbol      String  @unique
  name        String
  sector      String? // e.g. "เทคโนโลยี AI", "ซอฟต์แวร์"
  category    String  // "thai-stock", "reit", "dr", "us-stock", "etf-bond"
  yield       Float   // Annual yield percentage
  risk        Float   // Risk score 1-10
  badge       String  // "div", "growth", "alt"
  taxBase     Int     // Tax basis (0, 20, 30, 50)
  paysDividend Boolean
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  portfolioAllocations PortfolioAllocation[]
}

// Bank interest tier model
model BankTier {
  id          Int     @id @default(autoincrement())
  bankId      String  // "kkp_dime", "tcrb_alpha", etc.
  bankName    String
  minBalance  Int     // Minimum balance for this tier
  interestRate Float  // Annual interest rate
  createdAt   DateTime @default(now())

  @@unique([bankId, minBalance])
}

// Main Portfolio model
model Portfolio {
  id        Int     @id @default(autoincrement())
  name      String
  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  allocations PortfolioAllocation[]
}

// Portfolio allocation (junction table)
model PortfolioAllocation {
  id          Int     @id @default(autoincrement())
  portfolioId Int
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  assetId     Int
  asset       Asset   @relation(fields: [assetId], references: [id])
  allocation  Float   // Total Percentage allocation (0-100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions PortfolioTransaction[]

  @@unique([portfolioId, assetId])
}

// Portfolio transactions (DCA support)
model PortfolioTransaction {
  id                    Int                 @id @default(autoincrement())
  portfolioAllocationId Int
  portfolioAllocation   PortfolioAllocation @relation(fields: [portfolioAllocationId], references: [id], onDelete: Cascade)
  allocation            Float               // e.g. 10%
  buyDate               DateTime
  createdAt             DateTime            @default(now())
}

// Saved favorite portfolios
model SavedPortfolio {
  id        Int     @id @default(autoincrement())
  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  tool      String  // "t1", "wp", "ef"
  allocations Json   // Store allocation data as JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

